{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user profile with banking details",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "kycStatus": { "type": "string", "enum": ["unverified", "pending", "verified", "rejected"] },
        "walletBalance": { "type": "number" },
        "investmentBalance": { "type": "number" },
        "lastReturnCalculationDate": { "type": "string", "format": "date-time" },
        "savings": { "type": "number" },
        "activeCards": { "type": "number" },
        "activeLoanId": { "type": "string" },
        "dob": { "type": "string" },
        "address": { "type": "string" },
        "stateOfOrigin": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "employmentStatus": { "type": "string" },
        "employerName": { "type": "string" },
        "jobTitle": { "type": "string" },
        "monthlyIncome": { "type": "string" },
        "ssn": { "type": "string" },
        "idCardFrontImage": { "type": "string" },
        "idCardBackImage": { "type": "string" },
        "faceImage": { "type": "string" },
        "kycSubmittedAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "manager", "admin"], "default": "user" },
        "managerId": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bankName": { "type": "string" },
            "accountNumber": { "type": "string" },
            "accountName": { "type": "string" },
            "routingNumber": { "type": "string" }
          }
        },
        "cardDetails": {
          "type": "object",
          "properties": {
            "cardNumber": { "type": "string" },
            "expiryDate": { "type": "string" },
            "cvv": { "type": "string" },
            "pin": { "type": "string" }
          }
        }
      },
      "required": ["fullName", "email"]
    },
    "Transaction": {
      "title": "Banking Transaction",
      "description": "Record of a financial transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "send", "receive", "swap", "investment", "loan_repayment", "loan_disbursement"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["userId", "type", "amount", "status", "timestamp"]
    },
    "Loan": {
      "title": "Loan Application",
      "description": "Details of a loan request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "disbursed", "repaid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "duration", "status"]
    },
    "Settings": {
      "title": "App Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "usdt_address": { "type": "string" },
        "btc_address": { "type": "string" }
      }
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation between a user and a manager",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "managerId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageTimestamp": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "userId"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Investment": {
      "title": "User Investment",
      "description": "Record of an active investment strategy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "biweeklyReturn": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] }
      },
      "required": ["title", "amount", "biweeklyReturn", "timestamp", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/investments/{investmentId}": {
      "schema": "Investment",
      "description": "User specific investments"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction history"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Loan applications"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global app settings"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
