rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      );
    }

    function isManager() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'account_manager' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'manager')
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.email is string &&
             data.email.size() < 255 &&
             (!('role' in data) || data.role in ['user', 'account_manager', 'manager', 'admin']) &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('kycStatus' in data) || data.kycStatus in ['unverified', 'pending', 'verified', 'rejected']) &&
             (!('walletBalance' in data) || data.walletBalance is number) &&
             (!('savings' in data) || data.savings is number) &&
             (!('activeCards' in data) || data.activeCards is number) &&
             (!('activeLoanStatus' in data) || data.activeLoanStatus is string) &&
             (!('activeLoanId' in data) || data.activeLoanId is string) &&
             (!('emailVerified' in data) || data.emailVerified is bool) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('managerId' in data) || data.managerId is string) &&
             (!('rejectionReason' in data) || (data.rejectionReason is string || data.rejectionReason == null));
    }

    function isValidChat(data) {
      return data.userId is string &&
             data.managerId is string &&
             data.participants is list &&
             data.participants.size() >= 2 &&
             data.participants.size() <= 10;
    }

    function isValidMessage(data) {
      return data.senderId is string &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() < 5000 &&
             (!('timestamp' in data) || data.timestamp is timestamp) &&
             (!('read' in data) || data.read is bool);
    }

    function isValidLoan(data) {
      return data.userId is string &&
             data.amount is number &&
             data.amount > 0 &&
             data.amount < 10000000;
    }

    function isValidTransaction(data) {
      return data.userId is string &&
             data.type in ['deposit', 'send', 'receive', 'swap', 'investment', 'loan_repayment', 'loan_disbursement'] &&
             data.amount is number &&
             data.amount > 0 &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.timestamp is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        isManager() || 
        resource.data.get('role', 'user') in ['account_manager', 'manager', 'admin']
      );
      
      allow create: if isAuthenticated() && isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    request.resource.data.get('role', 'user') == 'user' &&
                    request.resource.data.get('walletBalance', 0) == 0;
      
      allow create: if isAdmin();

      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() ||
        ( (isOwner(userId) || isManager()) && 
          request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
        )
      );
    }

    // Transactions Collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin() || isManager());
      allow create: if isAuthenticated() && (isDocOwner(request.resource.data) || isAdmin()) && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner(resource.data));
      allow delete: if isAdmin();
    }

    // Loans Collection
    match /loans/{loanId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin() || isManager());
      allow create: if isAuthenticated() && isDocOwner(request.resource.data) && isValidLoan(request.resource.data);
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || isManager() || isDocOwner(resource.data));
      allow delete: if isAdmin();
    }

    // Notifications Collection (Subcollection Pattern)
    match /notifications/{userId}/items/{itemId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || isManager() || isOwner(userId) || userId == 'admin');
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Grants Collection
    match /grants/{grantId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin() || isManager());
      allow create: if isAuthenticated() && (isDocOwner(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || isManager() || isDocOwner(resource.data));
      allow delete: if isAdmin();
    }

    // Tax Filings Collection
    match /tax_filings/{filingId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin() || isManager());
      allow create: if isAuthenticated() && (isDocOwner(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || isManager() || isDocOwner(resource.data));
      allow delete: if isAdmin();
    }

    // Donations Collection
    match /donations/{donationId} {
      allow read: if isAuthenticated() && (isDocOwner(resource.data) || isAdmin() || isManager());
      allow create: if isAuthenticated() && (isDocOwner(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner(resource.data));
      allow delete: if isAdmin();
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Chats and Messages
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.managerId == request.auth.uid || 
        request.auth.uid in resource.data.participants || 
        isAdmin() || 
        isManager()
      );
      
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.managerId == request.auth.uid || 
        request.auth.uid in request.resource.data.participants || 
        isAdmin() || 
        isManager()
      );
      
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.managerId == request.auth.uid || 
        request.auth.uid in resource.data.participants || 
        isAdmin() || 
        isManager()
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.managerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || 
          isAdmin() || 
          isManager()
        );
        
        allow create: if isAuthenticated() && isValidMessage(request.resource.data) && (
          request.resource.data.senderId == request.auth.uid ||
          isAdmin() || 
          isManager()
        );
        
        allow update, delete: if isAdmin();
      }
    }
  }
}


